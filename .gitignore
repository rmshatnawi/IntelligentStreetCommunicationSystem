# ─── FIREBASE & SECRETS ─────────────────────────────────────
# NEVER push these — they give full access to your database
serviceAccountKey.json
*.key.json
.env


# ─── PYTHON ─────────────────────────────────────────────────
# Virtual environment — too large, recreated with pip install
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python


# ─── NODE / OLD FIREBASE FUNCTIONS ──────────────────────────
# Old JavaScript Firebase functions leftovers
node_modules/
*.log


# ─── FLUTTER ────────────────────────────────────────────────
# Build outputs and dependencies
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
*.iml


# ─── VS CODE ────────────────────────────────────────────────
.vscode/


# ─── SYSTEM FILES ───────────────────────────────────────────
.DS_Store
Thumbs.db